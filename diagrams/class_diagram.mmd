%% PawPal+ class diagram (Mermaid)
classDiagram
    class User {
        +String name
        +dict ownerPreferences
        +int timeAvailable
        +List~Pet~ pets
        +enter_info()
        +add_pet(Pet pet)
        +edit_pet(int pet_id, Pet updates)
        +remove_pet(int pet_id)
        +generate_schedule_for_pet(int pet_id) List~Task~
    }
    class Scheduler {
        +List~Task~ tasks
        +dict constraints
        +dict algorithmParams
        +score_task(Task task) float
        +prioritize_tasks() List~Task~
        +generate_schedule(int timeAvailable) List~Task~
        +explain_reasoning(List~Task~ schedule) String
    }

    class Task {
        +int id
        +String name
        +String category
        +int duration_minutes
        +int priority
        +String recurrence
        +date last_done
        +String notes
        +is_due() bool
        +to_dict() dict
    }
    class Pet {
        +int id
        +String name
        +String species
        +int age_years
        +String preferences
        +List~Task~ tasks
        +add_task(Task task)
        +edit_task(int task_id, Task updates)
        +remove_task(int task_id)
        +list_tasks() List~Task~
    }


    User "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    User ..> Scheduler : uses
    Scheduler "1" o-- "0..*" Task : scores/ranks
    
